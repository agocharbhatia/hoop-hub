{
  "name": "hoophub-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "bun src/server.ts",
    "bootstrap": "bun src/scripts/bootstrap.ts",
    "preflight": "bun src/scripts/preflight.ts",
    "ingest:status": "bun src/scripts/ingest-status.ts",
    "ingest:status:tunnel": "ENV_FILE=.env.tunnel bun src/scripts/ingest-status.ts",
    "ingest:unstick": "bun src/scripts/ingest-unstick.ts",
    "ingest:requeue-memory": "bun src/scripts/ingest-requeue-memory.ts",
    "worker:ingest": "bun src/workers/ingest.ts",
    "worker:ingest:tunnel": "ENV_FILE=.env.tunnel bun src/workers/ingest.ts",
    "worker:clips": "bun src/workers/clipCompilerWorker.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "ioredis": "^5.5.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "bun-types": "^1.1.29",
    "typescript": "^5.5.4"
  }
}
