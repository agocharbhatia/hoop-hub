# Lower-bound season for "modern era" coverage.
# Format: YYYY-YY
MODERN_ERA_START_SEASON=1996-97

# Future integration keys (not used by current slice):
# OPENAI_API_KEY=

# Optional SQLite path override for data/cache persistence.
# Use ':memory:' for ephemeral test runs.
# HOOP_HUB_DB_PATH=/absolute/path/to/hoop-hub.sqlite

# Enable live fetches against stats.nba.com.
# Set to 0, false, or off to force cache-only behavior.
# HOOP_HUB_ENABLE_LIVE_NBA=1

# Optional timeout for live NBA requests in milliseconds.
# Defaults to 5000.
# HOOP_HUB_NBA_TIMEOUT_MS=5000
